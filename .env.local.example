# .env.local — maintainer secrets for local dev
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Both `dev-chrome.sh` and `node dev-server.js` auto-load it on startup.
# Values set in the shell environment win over the file — drop an
# `export FOO=...` in your .bashrc if you want to override per-shell.
#
# Provision:
#   Oura     — https://cloud.ouraring.com/oauth/applications → create app
#   Withings — https://developer.withings.com/dashboard/ → register app
#   Polar    — https://admin.polaraccesslink.com/ → "Add new client"
# Set the same secrets on Vercel (Project → Settings → Environment Variables,
# mark Sensitive) so prod `/api/proxy` can exchange tokens too.

OURA_CLIENT_SECRET=
WITHINGS_CLIENT_SECRET=
ULTRAHUMAN_CLIENT_SECRET=
POLAR_CLIENT_SECRET=

# ── Self-hosting: OAuth client_id overrides ──
# The clientId baked into js/wearable-adapters.js is the maintainer's app
# (registered for *.getbased.health). Self-hosters running their own OAuth
# apps must override the client_id here so it matches the *_CLIENT_SECRET
# above — otherwise the provider returns invalid_client.
#
# When unset, the hardcoded maintainer values are used (current behavior).
# When set, the browser fetches the override on app init via /api/proxy and
# uses it for both the authorize URL and the token exchange.
#
# Provision your own OAuth apps in the same dev portals listed above and
# register your dev/prod redirect URIs (e.g. http://localhost:8000/app and
# https://your-host.example/app) in each portal.

OURA_CLIENT_ID=
WITHINGS_CLIENT_ID=
ULTRAHUMAN_CLIENT_ID=
POLAR_CLIENT_ID=
# Fitbit + WHOOP use PKCE — no client secret needed, but you still need
# your own client_id when self-hosting since the maintainer's client_id is
# registered to the maintainer's redirect URIs only.
FITBIT_CLIENT_ID=
WHOOP_CLIENT_ID=
#
# Apple Health is file-import — no credentials at all.

# ── CAMS atmosphere relay (powers the Sun Data Source `auto` mode) ──
# The local /api/proxy?meteo=cams handler forwards browser requests to
# getbased-uvdata, which fronts CAMS Atmospheric Composition Forecasts
# and merges Open-Meteo's hourly clouds/temp/UVI into one response.
# By default it uses the maintainer-hosted instance:
# https://uvdata.getbased.health
# The hosted instance requires UVDATA_BEARER. The bearer is injected
# server-side, so it never reaches the browser.
#
# UVDATA_UPSTREAM  — optional base URL override for the getbased-uvdata server.
#                    Leave blank for the hosted default above.
#                    Self-host example: https://your-uvdata.example.com
# UVDATA_BEARER    — bearer token registered in the uvdata server's
#                    GETBASED_UVDATA_BEARER env. Required for the hosted
#                    default. Treat like a credential.

UVDATA_UPSTREAM=
UVDATA_BEARER=

# ── Catalog deploy hooks (used by the getbased-tools editor's Deploy button)
# When set, /api/deploy-catalog runs two extra steps after writing
# data/recommendations.json: (1) git commit + push the catalog repo, then
# (2) POST a Vercel Deploy Hook to trigger a rebuild. Both are best-effort —
# missing config skips the step silently.
#
# CATALOG_GIT_REPO  — absolute path to the repo that owns the catalog file.
#                     Defaults to the repo containing the symlink target of
#                     data/recommendations.json (typically getbased-tools).
#                     Only needed when the auto-detect can't find it.
# CATALOG_COMMIT_MSG — override the commit message. Default: "catalog: deploy from editor"
# VERCEL_DEPLOY_HOOK_URL — Vercel → Settings → Git → Deploy Hooks → Create Hook
#                         (URL is the secret; treat it like a token)
CATALOG_GIT_REPO=
CATALOG_COMMIT_MSG=
VERCEL_DEPLOY_HOOK_URL=
