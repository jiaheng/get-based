# Version control and repository automation
.git
.gitignore
.github

# Dependency directories
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Build and release artifacts
dist
out
release
dist-docs
docs/.vitepress/cache

# Test and coverage artifacts
coverage
.nyc_output
test-results
playwright-report
test-screenshots
tests/.coverage.json
labcharts-*.json
test-*.json
test-data.json
*.lcov

# Local environment and secret files
.env
.env.*
!.env.example
.env.local
.env.*.local

# Generated/exported documents
*.pdf

# Note: .gitignore also ignores ad-hoc *.png files, but tracked app assets
# such as icons and screenshots should remain available to Docker builds.

# Local/editor files
.DS_Store
.idea
.vscode

# Local assistant/tool configuration
.claude
.mcp.json

# Local-only artifacts mirrored from .gitignore
BingSiteAuth.xml
docs/plans
tools
dev-chrome.sh
