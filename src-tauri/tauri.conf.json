{
  "$schema": "https://raw.githubusercontent.com/nickel-lang/json-schema-store/main/tauri.schema.json",
  "productName": "getbased",
  "version": "1.20.0",
  "identifier": "health.getbased.app",
  "build": {
    "frontendDist": "../src-tauri/dist",
    "devUrl": "http://localhost:8000/app",
    "beforeDevCommand": "",
    "beforeBuildCommand": "bash src-tauri/build-frontend.sh"
  },
  "app": {
    "windows": [
      {
        "title": "getbased — Health Dashboard",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://umami-iota-olive.vercel.app; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' ipc: http://ipc.localhost http://localhost:8322 http://127.0.0.1:8322 https:; font-src 'self' data: blob:",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/elkimek/get-based/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY_FROM_TAURI_SIGNER_GENERATE"
    }
  }
}
